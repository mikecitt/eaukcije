{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./backend/dist",
    "rootDir": "./backend/src",
    "skipLibCheck": true,
    "strictNullChecks": false,
    "noImplicitAny": false,
    "ignoreDeprecations": "5.0"
  },
  "include": ["backend/src/**/*"],
  "exclude": ["node_modules", "backend/dist"]
}
